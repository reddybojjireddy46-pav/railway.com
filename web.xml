<?xml version="1.0" encoding="UTF-8"?>
<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/javaee
         http://xmlns.jcp.org/xml/ns/javaee/web-app_4_0.xsd"
         version="4.0">

    <display-name>RailYatra - Railway Reservation System</display-name>

    <welcome-file-list>
        <welcome-file>index.html</welcome-file>
    </welcome-file-list>

    <!-- Search Trains Servlet -->
    <servlet>
        <servlet-name>SearchTrainsServlet</servlet-name>
        <servlet-class>com.railway.servlet.SearchTrainsServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>SearchTrainsServlet</servlet-name>
        <url-pattern>/search</url-pattern>
    </servlet-mapping>

    <!-- Book Ticket Servlet -->
    <servlet>
        <servlet-name>BookTicketServlet</servlet-name>
        <servlet-class>com.railway.servlet.BookTicketServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>BookTicketServlet</servlet-name>
        <url-pattern>/book</url-pattern>
    </servlet-mapping>

    <!-- View Ticket Servlet -->
    <servlet>
        <servlet-name>TicketServlet</servlet-name>
        <servlet-class>com.railway.servlet.TicketServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>TicketServlet</servlet-name>
        <url-pattern>/ticket</url-pattern>
    </servlet-mapping>

    <!-- Cancel Ticket Servlet -->
    <servlet>
        <servlet-name>CancelTicketServlet</servlet-name>
        <servlet-class>com.railway.servlet.CancelTicketServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>CancelTicketServlet</servlet-name>
        <url-pattern>/cancel</url-pattern>
    </servlet-mapping>

</web-app>
